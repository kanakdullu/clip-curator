# Copy this file to .env and fill in values for your environment

# AWS / S3
AWS_REGION=us-east-1
CLIPCURATOR_S3_BUCKET=clip-curator

# Local AI service endpoints
CLIPCURATOR_WHISPER_URL=http://127.0.0.1:8000/models/openai/whisper-transcribe
CLIPCURATOR_CLIP_URL=http://127.0.0.1:8000/pipeline/feature-extraction/sentence-transformers/clip-ViT-B-32

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=clipcurator-index
PINECONE_NAMESPACE=default

# Search
CLIPCURATOR_SEARCH_TOP_K=50
CLIPCURATOR_SEARCH_MINIMUM_SCORE=0.15

# Processing
CLIPCURATOR_TMP_DIR=/tmp/clipcurator/assets
CLIPCURATOR_FRAME_SAMPLING_FPS=1.0
FFMPEG_COMMAND=ffmpeg
FFPROBE_COMMAND=ffprobe
